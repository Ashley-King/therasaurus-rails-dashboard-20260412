# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key


/app/assets/builds/*
!/app/assets/builds/.keep

# Claude Code per-machine state.
# - worktrees/          temporary isolated-work scratch (not source)
# - settings.local.json per-machine settings (the name says it)
# - projects/           per-machine session/conversation/memory cache
# Note: .claude/launch.json + .claude/skills/ are intentionally tracked.
.claude/worktrees/
.claude/settings.local.json
.claude/projects/
