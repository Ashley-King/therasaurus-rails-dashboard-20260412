<h2 class="ts-auth-title mb-6">Sign in to your account</h2>

<%= form_with url: signin_path, method: :post, class: "space-y-6", data: { turbo: false } do |f| %>
  <div>
    <%= f.label :email, "Email address", class: "block text-base font-medium text-gray-700" %>
    <div class="mt-2">
      <%= f.email_field :email, required: true, autofocus: true,
        class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-teal-600 sm:text-sm sm:leading-6 px-3",
        placeholder: "you@example.com" %>
    </div>
  </div>

  <div>
    <%= f.submit "Send verification code",
      class: "ts-btn-primary w-full px-6 py-2.5" %>
  </div>
<% end %>

<p class="mt-6 text-center text-sm text-gray-500">
  We'll send a one-time code to your email.
</p>
