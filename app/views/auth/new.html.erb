<% content_for(:auth_card_class) { "ts-auth-card ts-auth-card-signin" } %>

<h2 class="ts-auth-title mb-6">Sign in or create your account</h2>

<% content_for :head do %>
  <%= javascript_include_tag "https://challenges.cloudflare.com/turnstile/v0/api.js", async: true, defer: true %>
<% end %>

<%= button_to signin_google_path,
  method: :post,
  form: { data: { turbo: false }, class: "mb-6" },
  class: "ts-btn-outline w-full px-6 py-2.5 inline-flex items-center justify-center gap-2" do %>
  <svg class="h-5 w-5 shrink-0" aria-hidden="true" viewBox="0 0 24 24">
    <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" />
    <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
    <path fill="#FBBC05" d="M5.84 14.1c-.22-.66-.35-1.36-.35-2.1s.13-1.44.35-2.1V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l3.66-2.84z" />
    <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06L5.84 9.9C6.71 7.31 9.14 5.38 12 5.38z" />
  </svg>
  <span>Continue with Google</span>
<% end %>

<div class="relative mb-6" aria-hidden="true">
  <div class="absolute inset-0 flex items-center">
    <div class="w-full border-t border-gray-200"></div>
  </div>
  <div class="relative flex justify-center">
    <span class="bg-surface-secondary px-3 text-sm text-gray-500 sm:bg-white">Or continue with email</span>
  </div>
</div>

<%= form_with url: signin_path, method: :post, class: "space-y-6", data: { turbo: false } do |f| %>
  <div>
    <%= f.label :email, "Email address", class: "block text-base font-medium text-gray-700" %>
    <div class="mt-2">
      <%= f.email_field :email, required: true, autofocus: true,
        class: "block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-plum sm:text-sm sm:leading-6 px-3",
        placeholder: "you@example.com",
        value: @email %>
    </div>
  </div>

  <div class="ts-turnstile-field">
    <div
      id="signin-turnstile"
      class="cf-turnstile w-full"
      data-sitekey="<%= @turnstile_site_key %>"
      data-theme="light"
      data-size="flexible"
      data-response-field-name="cf-turnstile-response">
    </div>
  </div>

  <div>
    <%= f.submit "Get a sign in code",
      class: "ts-btn-primary w-full px-6 py-2.5" %>
  </div>
<% end %>

<p class="mt-6 text-center text-sm text-gray-500">
  We'll send a code to your email.
</p>
