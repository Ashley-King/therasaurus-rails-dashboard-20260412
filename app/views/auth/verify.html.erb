<h2 class="ts-auth-title mb-6">Verify your email</h2>

<p class="text-sm text-gray-500 mb-6">
  We sent a verification code to <strong><%= @email %></strong>
</p>

<%= form_with url: verify_path, method: :post, class: "space-y-6", data: { controller: "otp-input", turbo: false } do |f| %>
  <div>
    <%= f.label :token, "Verification code", class: "block text-base font-medium text-gray-700" %>
    <div class="mt-2">
      <%= f.text_field :token, required: true, autofocus: true, autocomplete: "one-time-code", inputmode: "numeric", maxlength: 8, minlength: 8,
        class: "block w-full rounded-md border-0 py-3 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-teal-600 tracking-[0.3em] text-center text-2xl font-mono px-3",
        placeholder: "00000000",
        data: { otp_input_target: "input", action: "input->otp-input#validate" } %>
    </div>
  </div>

  <div>
    <%= f.submit "Verify", disabled: true,
      class: "ts-btn-primary w-full px-6 py-2.5",
      data: { otp_input_target: "submit" } %>
  </div>
<% end %>

<p class="mt-6 text-center text-sm text-gray-500">
  <%= link_to "Use a different email", signin_path, class: "text-teal-600 hover:text-teal-500 hover:underline" %>
</p>
