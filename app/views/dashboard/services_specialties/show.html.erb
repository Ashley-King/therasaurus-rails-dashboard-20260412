<h1 class="text-2xl font-bold text-gray-900 mb-6">Services & Specialties</h1>

<div class="bg-white shadow sm:rounded-lg p-6">
  <p class="text-sm text-gray-500 mb-4">Select the services and specialties that describe your practice.</p>

  <div class="mb-8">
    <h2 class="text-lg font-medium text-gray-900 mb-3">Your Specialties</h2>
    <p class="text-sm text-gray-500">
      <%= therapist.specialties.order(:name).pluck(:name).join(", ").presence || "None selected" %>
    </p>
  </div>

  <div class="mb-8">
    <h2 class="text-lg font-medium text-gray-900 mb-3">Your Services</h2>
    <p class="text-sm text-gray-500">
      <%= therapist.services.order(:name).pluck(:name).join(", ").presence || "None selected" %>
    </p>
  </div>

  <div>
    <h2 class="text-lg font-medium text-gray-900 mb-3">Age Groups</h2>
    <p class="text-sm text-gray-500">
      <%= therapist.age_groups.order(:name).pluck(:name).join(", ").presence || "None selected" %>
    </p>
  </div>
</div>
