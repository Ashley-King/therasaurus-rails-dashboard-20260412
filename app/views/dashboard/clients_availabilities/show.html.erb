<h1 class="text-2xl font-bold text-gray-900 mb-6">Clients & Availability</h1>

<div class="bg-white shadow sm:rounded-lg p-6">
  <%= form_with model: therapist, url: dashboard_clients_availability_path, method: :patch, class: "space-y-6" do |f| %>
    <fieldset data-controller="mutual-exclusion">
      <legend class="text-sm font-medium text-gray-700 mb-3">Client status</legend>
      <div class="space-y-2">
        <div class="flex items-center gap-2">
          <%= f.check_box :accepting_new_clients,
            class: "rounded border-gray-300 text-teal-600 focus:ring-teal-500",
            data: { mutual_exclusion_target: "first", action: "change->mutual-exclusion#uncheckSecond" } %>
          <%= f.label :accepting_new_clients, "Accepting new clients", class: "text-sm text-gray-700" %>
        </div>
        <div class="flex items-center gap-2">
          <%= f.check_box :has_waitlist,
            class: "rounded border-gray-300 text-teal-600 focus:ring-teal-500",
            data: { mutual_exclusion_target: "second", action: "change->mutual-exclusion#uncheckFirst" } %>
          <%= f.label :has_waitlist, "Maintain a waitlist", class: "text-sm text-gray-700" %>
        </div>
        <div class="flex items-center gap-2">
          <%= f.check_box :free_phone_call, class: "rounded border-gray-300 text-teal-600 focus:ring-teal-500" %>
          <%= f.label :free_phone_call, "Offer free phone consultation", class: "text-sm text-gray-700" %>
        </div>
      </div>
    </fieldset>

    <fieldset>
      <legend class="text-sm font-medium text-gray-700 mb-3">Session format</legend>
      <div class="space-y-2">
        <% SessionFormat.order(:name).each do |format| %>
          <div class="flex items-center gap-2">
            <%= check_box_tag "therapist[session_format_ids][]", format.id,
              therapist.session_format_ids.include?(format.id),
              id: "session_format_#{format.id}",
              class: "rounded border-gray-300 text-teal-600 focus:ring-teal-500" %>
            <%= label_tag "session_format_#{format.id}", format.name, class: "text-sm text-gray-700" %>
          </div>
        <% end %>
        <%= hidden_field_tag "therapist[session_format_ids][]", "" %>
      </div>
    </fieldset>

    <fieldset>
      <legend class="text-sm font-medium text-gray-700 mb-3">Session modality</legend>
      <div class="space-y-2">
        <div class="flex items-center gap-2">
          <%= f.check_box :in_person, class: "rounded border-gray-300 text-teal-600 focus:ring-teal-500" %>
          <%= f.label :in_person, "In-person", class: "text-sm text-gray-700" %>
        </div>
        <div class="flex items-center gap-2">
          <%= f.check_box :virtual, class: "rounded border-gray-300 text-teal-600 focus:ring-teal-500" %>
          <%= f.label :virtual, "Virtual/telehealth", class: "text-sm text-gray-700" %>
        </div>
      </div>
    </fieldset>

    <fieldset>
      <legend class="text-sm font-medium text-gray-700 mb-3">Availability</legend>
      <div class="space-y-2">
        <div class="flex items-center gap-2">
          <%= f.check_box :early_morning, class: "rounded border-gray-300 text-teal-600 focus:ring-teal-500" %>
          <%= f.label :early_morning, "Early morning (before 8am)", class: "text-sm text-gray-700" %>
        </div>
        <div class="flex items-center gap-2">
          <%= f.check_box :evening, class: "rounded border-gray-300 text-teal-600 focus:ring-teal-500" %>
          <%= f.label :evening, "Evening (after 6pm)", class: "text-sm text-gray-700" %>
        </div>
        <div class="flex items-center gap-2">
          <%= f.check_box :weekend, class: "rounded border-gray-300 text-teal-600 focus:ring-teal-500" %>
          <%= f.label :weekend, "Weekends", class: "text-sm text-gray-700" %>
        </div>
      </div>
    </fieldset>

    <div>
      <%= f.label :availability_notes, "Additional notes", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :availability_notes, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 sm:text-sm px-3 py-2 border" %>
    </div>

    <div>
      <%= f.submit "Save", class: "rounded-md bg-teal-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 cursor-pointer" %>
    </div>
  <% end %>
</div>
