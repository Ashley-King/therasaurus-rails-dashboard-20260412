<h1 class="text-2xl font-bold text-gray-900 mb-6">Practice Details</h1>

<div class="bg-white shadow sm:rounded-lg p-6">
  <%= form_with model: therapist, url: dashboard_practice_details_path, method: :patch, class: "space-y-6" do |f| %>
    <div>
      <%= f.label :practice_name, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :practice_name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 sm:text-sm px-3 py-2 border" %>
    </div>

    <div class="flex items-center gap-2">
      <%= f.check_box :use_practice_name, class: "rounded border-gray-300 text-teal-600 focus:ring-teal-500" %>
      <%= f.label :use_practice_name, "Display practice name instead of personal name", class: "text-sm text-gray-700" %>
    </div>

    <div>
      <%= f.label :practice_website_url, "Website", class: "block text-sm font-medium text-gray-700" %>
      <%= f.url_field :practice_website_url, placeholder: "https://", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 sm:text-sm px-3 py-2 border" %>
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <div>
        <%= f.label :phone_number, class: "block text-sm font-medium text-gray-700" %>
        <%= f.phone_field :phone_number, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 sm:text-sm px-3 py-2 border" %>
      </div>
      <div>
        <%= f.label :phone_ext, "Extension", class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :phone_ext, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 sm:text-sm px-3 py-2 border" %>
      </div>
    </div>

    <div>
      <%= f.label :practice_description, "About your practice", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :practice_description, rows: 6, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-teal-500 focus:ring-teal-500 sm:text-sm px-3 py-2 border" %>
    </div>

    <div>
      <%= f.submit "Save", class: "rounded-md bg-teal-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-teal-500 cursor-pointer" %>
    </div>
  <% end %>
</div>

<% if @locations.any? %>
  <div class="mt-8 bg-white shadow sm:rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Locations</h2>
    <% @locations.each do |location| %>
      <div class="border-b border-gray-200 py-3 last:border-0">
        <p class="text-sm font-medium text-gray-900"><%= location.location_type&.titleize %> Location</p>
        <p class="text-sm text-gray-500"><%= location.full_address %></p>
      </div>
    <% end %>
  </div>
<% end %>
