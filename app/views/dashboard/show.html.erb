<% content_for :page_header do %>
  <div class="md:flex md:items-center md:justify-between">
    <div class="flex-1 min-w-0">
      <h1 class="font-heading text-3xl md:text-4xl font-light text-text-primary">Dashboard</h1>
    </div>
    <div class="mt-4 flex flex-wrap gap-3 md:mt-0 md:ml-4">
      <%# Share button with dropdown %>
      <div class="relative" data-controller="dropdown">
        <button type="button"
                data-action="click->dropdown#toggle"
                class="ts-btn-outline px-4 py-2 inline-flex items-center gap-2">
          <% if current_user.membership_status == "member" %>
            <svg class="h-4 w-4 text-amber-600" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
          <% end %>
          Share
        </button>

        <div data-dropdown-target="menu"
             class="hidden absolute right-0 mt-2 w-80 rounded-xl bg-white shadow-lg ring-1 ring-black/5 z-20">
          <div class="p-5">
            <% if current_user.membership_status == "member" %>
              <p class="text-sm font-semibold text-amber-600 mb-4">
                <svg class="inline h-4 w-4 -mt-0.5 mr-1" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
                Subscribe to activate your profile.
              </p>
            <% end %>

            <div class="flex items-center gap-2 mb-3">
              <div class="h-8 w-8 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0">
                <svg class="h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
              </div>
              <span class="text-sm font-semibold text-text-primary">Your Profile Link</span>
            </div>

            <% profile_url = "therasaurus.org/therapists/#{current_therapist&.profile_slug}" %>

            <% if current_user.membership_status == "member" %>
              <%# Disabled state for free members %>
              <div class="select-none">
                <input type="text"
                       value="<%= profile_url %>"
                       readonly
                       disabled
                       class="w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2.5 text-sm text-gray-400"
                       aria-label="Profile link">
                <a href="#" class="mt-3 ts-btn-primary px-4 py-2 inline-flex items-center gap-2 text-sm w-full justify-center" aria-disabled="false">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M7 7h10v10" /></svg>
                  Choose a plan
                </a>
              </div>
            <% else %>
              <%# Active state for paid members %>
              <div data-controller="clipboard">
                <div class="flex gap-2">
                  <input type="text"
                         value="<%= profile_url %>"
                         readonly
                         data-clipboard-target="source"
                         class="w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2.5 text-sm text-text-muted"
                         aria-label="Profile link">
                  <button type="button"
                          data-action="click->clipboard#copy"
                          data-clipboard-target="button"
                          title="Copy Link"
                          class="flex-shrink-0 rounded-lg border border-gray-200 h-10 w-10 hover:bg-gray-50 transition flex flex-col items-center justify-center cursor-pointer focus:outline-none focus:ring-2 focus:ring-plum focus:ring-offset-1 overflow-hidden"
                          aria-label="Copy Link">
                    <svg class="h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                  </button>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <a href="#" class="ts-btn-primary px-4 py-2 inline-flex items-center gap-2">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>
        View public profile
      </a>
    </div>
  </div>
<% end %>

<%# ── Profile card ── %>
<div class="ts-card p-8 md:p-10">
  <h2 class="text-2xl font-heading font-semibold text-text-primary">
    <% if current_therapist&.first_name.present? %>
      <%= current_therapist.full_name %><% if current_therapist.credentials.present? %>, <%= current_therapist.credentials %><% end %>
    <% else %>
      Welcome!
    <% end %>
  </h2>

  <% if current_therapist&.profession.present? %>
    <p class="mt-1 text-sm text-text-muted"><%= current_therapist.profession.name %></p>
  <% end %>

  <%# Membership & verification %>
  <div class="mt-6 space-y-3">
    <div class="flex items-center gap-2">
      <span class="text-sm font-medium text-text-secondary">Membership</span>
      <% case current_user.membership_status %>
      <% when "pro" %>
        <span class="ts-badge-membership-pro">TheraSaurus Pro</span>
      <% when "trial" %>
        <span class="ts-badge-membership-trial">Free Trial</span>
      <% else %>
        <span class="ts-badge-membership-free">Free</span>
      <% end %>
    </div>

    <div class="flex items-center gap-2">
      <span class="text-sm font-medium text-text-secondary">Verification</span>
      <span class="ts-badge-attention">Unverified</span>
    </div>

    <%# Profile completeness hint %>
    <% if current_therapist.nil? || current_therapist.first_name.blank? %>
      <div class="mt-4 rounded-lg bg-plum-bg p-4">
        <p class="text-sm text-plum font-medium">Complete your profile to get listed</p>
        <p class="mt-1 text-xs text-text-muted">Start by adding your professional identity and practice details.</p>
        <a href="<%= professional_identity_path %>" class="mt-3 inline-block text-sm font-semibold text-plum hover:text-plum-dark">
          Get started &#8594;
        </a>
      </div>
    <% end %>
  </div>
</div>
