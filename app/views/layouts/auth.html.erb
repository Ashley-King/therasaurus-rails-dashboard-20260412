<!DOCTYPE html>
<html lang="en" class="h-full bg-surface-secondary">
<head>
  <title>TheraSaurus - Sign In</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "tailwind", "fonts", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="h-full font-body text-text-body">
  <div class="flex min-h-full flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
      <%= image_tag "logo.svg", alt: "TheraSaurus", class: "mx-auto w-[100px] lg:w-[150px] h-auto" %>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full <%= content_for?(:auth_max_width) ? yield(:auth_max_width) : 'sm:max-w-md' %>">
      <div class="<%= content_for?(:auth_card_class) ? yield(:auth_card_class) : 'ts-auth-card' %> mx-auto">
        <% if flash[:alert] %>
          <div class="mb-4 rounded-md bg-status-attention-bg p-4">
            <p class="text-sm text-status-attention"><%= flash[:alert] %></p>
          </div>
        <% end %>
        <% if flash[:notice] %>
          <div class="ts-banner-info mb-4">
            <p class="text-sm text-teal-dark"><%= flash[:notice] %></p>
          </div>
        <% end %>
        <%= yield %>
      </div>
    </div>
  </div>
</body>
</html>
