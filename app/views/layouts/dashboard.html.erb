<!DOCTYPE html>
<html lang="en" class="h-full bg-surface-secondary">
<head>
  <title><%= content_for(:title) || "TheraSaurus" %></title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "cropperjs", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "trix", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="h-full font-body text-text-body">
  <div class="min-h-screen flex flex-col">

    <%# ── Pending-geocode banner ── %>
    <% if current_therapist&.primary_location&.geocode_status == "pending" %>
      <div class="container max-w-6xl px-5 md:px-7 mx-auto">
        <div class="my-5 rounded-xl bg-blue-50 border border-blue-200 px-6 py-4">
          <div class="sm:flex items-center">
            <div class="-mt-0.5 w-7 text-blue-600">
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
            </div>
            <div>
              <p class="text-sm font-semibold text-blue-700">Finalizing your location</p>
              <p class="mt-0.5 text-xs font-medium text-text-muted max-w-2xl">Your profile will appear in search results within a few minutes.</p>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <%# ── Membership banner (above nav) ── %>
    <%
      banner_state = nil
      if current_user&.is_admin
        banner_state = params[:banner_preview] == "active" ? "active" : "ended"
      elsif current_user && current_user.membership_status != "pro"
        trial_ended = current_user.membership_status == "trial" && current_user.trial_ends_at.present? && current_user.trial_ends_at <= Time.current
        banner_state = trial_ended ? "ended" : "active"
      end
    %>
    <% if banner_state %>
      <div class="bg-white">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="my-5 rounded-xl bg-plum-bg px-6 py-4 w-full">
            <div class="sm:flex sm:items-center sm:gap-6">
              <div class="flex items-start gap-3 flex-1">
                <% if banner_state == "ended" %>
                  <svg class="h-6 w-6 text-plum shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                    <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                  </svg>
                <% else %>
                  <svg class="h-6 w-6 text-plum shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M5.8 11.3 2 22l10.7-3.79" />
                    <path d="M4 3h.01" />
                    <path d="M22 8h.01" />
                    <path d="M15 2h.01" />
                    <path d="M22 20h.01" />
                    <path d="m22 2-2.24.75a2.9 2.9 0 0 0-1.96 3.12c.1.86-.57 1.63-1.45 1.63h-.38c-.86 0-1.6.6-1.76 1.44L14 10" />
                    <path d="m22 13-.82-.33c-.86-.34-1.82.2-1.98 1.11c-.11.7-.72 1.22-1.43 1.22H17" />
                    <path d="m11 2 .33.82c.34.86-.2 1.82-1.11 1.98C9.52 4.9 9 5.52 9 6.23V7" />
                    <path d="M11 13c1.93 1.93 2.83 4.17 2 5-.83.83-3.07-.07-5-2-1.93-1.93-2.83-4.17-2-5 .83-.83 3.07.07 5 2Z" />
                  </svg>
                <% end %>
                <div>
                  <% if banner_state == "ended" %>
                    <p class="text-sm font-semibold text-plum">Your trial has ended &mdash; Get your profile back online</p>
                    <p class="mt-0.5 text-xs font-medium text-text-muted max-w-2xl">Your profile is offline, and parents who need you can&rsquo;t find you.</p>
                  <% else %>
                    <p class="text-sm font-semibold text-plum">Your profile is online</p>
                    <p class="mt-0.5 text-xs font-medium text-text-muted max-w-2xl">Customize it with your information so the right families can find you.</p>
                  <% end %>
                </div>
              </div>
              <%= link_to membership_path,
                    class: "mt-3 sm:mt-0 inline-flex items-center gap-1 text-xs font-semibold text-plum hover:underline focus-visible:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-plum rounded shrink-0 cursor-pointer" do %>
                <%= banner_state == "ended" ? "Join now and go live" : "Choose a plan" %>
                <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7V17" />
                </svg>
              <% end %>
            </div>
            <% if current_user&.is_admin %>
              <% next_state = banner_state == "ended" ? "active" : "ended" %>
              <% switch_url = "#{request.path}?#{request.query_parameters.merge(banner_preview: next_state).to_query}" %>
              <p class="mt-2 pl-9 text-xs text-text-muted">
                <span class="italic">Admin preview &mdash; showing &ldquo;<%= banner_state %>&rdquo; state.</span>
                <%= link_to "Switch", switch_url, class: "ml-1 font-semibold text-plum hover:underline focus-visible:underline cursor-pointer" %>
              </p>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <%# ── Top navigation ── %>
    <div id="top-nav" class="bg-white <%= banner_state ? 'shadow-[0_2px_4px_-1px_rgba(0,0,0,0.06)]' : 'shadow' %> select-none" data-turbo-permanent>
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="relative bg-white">
          <div class="flex justify-between items-center py-3 lg:space-x-10">
            <%# Logo %>
            <div class="flex-shrink-0">
              <%= link_to account_settings_path do %>
                <%= image_tag "logo.svg", alt: "TheraSaurus", class: "h-12 w-auto" %>
              <% end %>
            </div>

            <%# Desktop nav links %>
            <nav class="hidden lg:flex space-x-6 lg:space-x-10" aria-label="Main navigation">
              <%= dashboard_topnav_link "Your Account", account_settings_path %>
              <%= dashboard_topnav_link "About You", about_you_path %>
              <%= dashboard_topnav_link "Your Practice", your_practice_path %>
            </nav>

            <%# Right side: Share button + avatar dropdown (desktop) + hamburger (mobile) %>
            <div class="flex grow justify-end items-center lg:grow-0 gap-3">
              <%# Share button with dropdown (desktop) %>
              <div class="hidden lg:block relative" data-controller="dropdown">
                <button type="button"
                        data-action="click->dropdown#toggle"
                        class="ts-btn-outline px-3 py-1.5 inline-flex items-center gap-2 text-sm cursor-pointer">
                  <% if current_user&.membership_status == "member" %>
                    <svg class="h-4 w-4 text-amber-600" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
                  <% end %>
                  Share
                </button>

                <div data-dropdown-target="menu"
                     class="hidden absolute right-0 mt-2 w-80 rounded-xl bg-white shadow-lg ring-1 ring-black/5 z-20">
                  <div class="p-5">
                    <% if current_user&.membership_status == "member" %>
                      <p class="text-sm font-semibold text-amber-600 mb-4">
                        <svg class="inline h-4 w-4 -mt-0.5 mr-1" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" /></svg>
                        Subscribe to activate your profile.
                      </p>
                    <% end %>

                    <div class="flex items-center gap-2 mb-3">
                      <div class="h-8 w-8 rounded-full bg-gray-100 flex items-center justify-center flex-shrink-0">
                        <svg class="h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" /></svg>
                      </div>
                      <span class="text-sm font-semibold text-text-primary">Your Profile Link</span>
                    </div>

                    <% profile_display_url = "therasaurus.org/therapists/#{current_therapist&.profile_slug}" %>
                    <% profile_copy_url = "https://#{profile_display_url}" %>

                    <% if current_user&.membership_status == "member" %>
                      <div class="select-none">
                        <input type="text"
                               value="<%= profile_display_url %>"
                               readonly
                               disabled
                               class="w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2.5 text-sm text-gray-400"
                               aria-label="Profile link">
                        <a href="#" class="mt-3 ts-btn-primary px-4 py-2 inline-flex items-center gap-2 text-sm w-full justify-center" aria-disabled="false">
                          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M7 7h10v10" /></svg>
                          Choose a plan
                        </a>
                      </div>
                    <% else %>
                      <div data-controller="clipboard" data-clipboard-copy-value="<%= profile_copy_url %>">
                        <div class="flex gap-2">
                          <input type="text"
                                 value="<%= profile_display_url %>"
                                 readonly
                                 data-clipboard-target="source"
                                 class="w-full rounded-lg border border-gray-200 bg-gray-50 px-3 py-2.5 text-sm text-text-muted"
                                 aria-label="Profile link">
                          <button type="button"
                                  data-action="click->clipboard#copy"
                                  data-clipboard-target="button"
                                  title="Copy Link"
                                  class="flex-shrink-0 rounded-lg border border-gray-200 h-10 w-10 hover:bg-gray-50 transition flex flex-col items-center justify-center cursor-pointer focus:outline-none focus:ring-2 focus:ring-plum focus:ring-offset-1 overflow-hidden"
                                  aria-label="Copy Link">
                            <svg class="h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
                          </button>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              </div>

              <%# Desktop avatar dropdown %>
              <div class="hidden lg:flex">
                <div class="relative" data-controller="dropdown">
                  <button type="button"
                          data-action="click->dropdown#toggle"
                          class="flex text-sm border-2 border-transparent rounded-full focus:outline-none focus:border-gray-300 transition duration-150 ease-in-out"
                          aria-haspopup="true">
                    <span class="sr-only">Open account menu</span>
                    <% if current_therapist&.practice_image_url.present? %>
                      <img src="<%= current_therapist.practice_image_url %>"
                           alt="Profile photo"
                           class="js-nav-avatar h-8 w-8 rounded-full object-cover cursor-pointer">
                    <% else %>
                      <span class="js-nav-avatar inline-flex items-center justify-center h-8 w-8 rounded-full bg-plum-bg text-plum font-semibold text-sm cursor-pointer">
                        <%= initials_for(current_therapist, current_user) %>
                      </span>
                    <% end %>
                  </button>
                  <div data-dropdown-target="menu"
                       class="hidden origin-top-right absolute right-0 mt-2 w-48 rounded-md shadow-lg z-20"
                       role="menu" aria-orientation="vertical" aria-labelledby="user-menu">
                    <div class="py-1 rounded-md bg-white ring-1 ring-black/5">
                      <a href="#" class="block px-4 py-2 mb-0 text-sm leading-5 text-gray-700 hover:bg-gray-100 focus:outline-none focus:bg-gray-100 transition duration-150 ease-in-out" role="menuitem">Integrations</a>
                      <a href="#" class="block px-4 py-2 mb-0 text-sm leading-5 text-gray-700 hover:bg-gray-100 focus:outline-none focus:bg-gray-100 transition duration-150 ease-in-out" role="menuitem">Support</a>
                      <% if current_user&.is_admin? %>
                        <div class="border-b border-1 my-2 border-gray-200"></div>
                        <%= link_to "Admin", "/admin", class: "block px-4 py-2 mb-0 text-sm leading-5 text-gray-700 hover:bg-gray-100 focus:outline-none focus:bg-gray-100 transition duration-150 ease-in-out", role: "menuitem" %>
                      <% end %>
                      <%= button_to "Sign out", signout_path, method: :delete,
                            class: "block w-full text-left px-4 py-2 mb-0 text-sm leading-5 text-gray-700 hover:bg-gray-100 focus:outline-none focus:bg-gray-100 transition duration-150 ease-in-out",
                            role: "menuitem" %>
                    </div>
                  </div>
                </div>
              </div>

              <%# Mobile hamburger menu %>
              <div class="lg:hidden ml-4" data-controller="dropdown">
                <div class="-mr-2 -my-2">
                  <button type="button"
                          data-action="click->dropdown#toggle"
                          class="inline-flex items-center justify-center p-2 rounded-md text-gray-400 hover:bg-gray-100 focus:outline-none focus:bg-gray-100 focus:text-gray-500 transition duration-150 ease-in-out"
                          aria-label="Toggle navigation menu">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    </svg>
                  </button>
                </div>
                <div data-dropdown-target="menu"
                     class="hidden origin-top-right absolute right-0 mt-2 w-48 rounded-md shadow-lg z-10 lg:hidden"
                     role="menu" aria-orientation="vertical">
                  <div class="py-1 rounded-md bg-white ring-1 ring-black/5">
                    <%= link_to "Your Account", account_settings_path, class: "block px-4 py-2 mb-0 text-sm leading-5 text-gray-700 hover:bg-gray-100 focus:outline-none focus:bg-gray-100 transition duration-150 ease-in-out", role: "menuitem" %>
                    <%= link_to "About You", about_you_path, class: "block px-4 py-2 mb-0 text-sm leading-5 text-gray-700 hover:bg-gray-100 focus:outline-none focus:bg-gray-100 transition duration-150 ease-in-out", role: "menuitem" %>
                    <%= link_to "Your Practice", your_practice_path, class: "block px-4 py-2 mb-0 text-sm leading-5 text-gray-700 hover:bg-gray-100 focus:outline-none focus:bg-gray-100 transition duration-150 ease-in-out", role: "menuitem" %>
                    <div class="border-b border-1 my-2 border-gray-200"></div>
                    <a href="#" class="block px-4 py-2 mb-0 text-sm leading-5 text-gray-700 hover:bg-gray-100 focus:outline-none focus:bg-gray-100 transition duration-150 ease-in-out" role="menuitem">Integrations</a>
                    <a href="#" class="block px-4 py-2 mb-0 text-sm leading-5 text-gray-700 hover:bg-gray-100 focus:outline-none focus:bg-gray-100 transition duration-150 ease-in-out" role="menuitem">Support</a>
                    <% if current_user&.is_admin? %>
                      <div class="border-b border-1 my-2 border-gray-200"></div>
                      <%= link_to "Admin", "/admin", class: "block px-4 py-2 mb-0 text-sm leading-5 text-gray-700 hover:bg-gray-100 focus:outline-none focus:bg-gray-100 transition duration-150 ease-in-out", role: "menuitem" %>
                    <% end %>
                    <div class="border-b border-1 my-2 border-gray-200"></div>
                    <%= button_to "Sign out", signout_path, method: :delete,
                          class: "block w-full text-left px-4 py-2 mb-0 text-sm leading-5 text-gray-700 hover:bg-gray-100 focus:outline-none focus:bg-gray-100 transition duration-150 ease-in-out",
                          role: "menuitem" %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%# ── Page header with title ── %>
    <% if content_for?(:page_header) %>
      <div>
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-4 sm:py-8 lg:py-12">
          <%= yield :page_header %>
        </div>
      </div>
    <% end %>

    <%# ── Flash messages ── %>
    <% if flash[:notice] || flash[:alert] %>
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
        <% if flash[:notice] %>
          <div class="ts-banner-info mb-3">
            <p class="text-sm text-teal-dark"><%= flash[:notice] %></p>
          </div>
        <% end %>
        <% if flash[:alert] %>
          <div class="mb-3 rounded-lg bg-status-attention-bg border border-red-200 p-4">
            <p class="text-sm text-status-attention"><%= flash[:alert] %></p>
          </div>
        <% end %>
      </div>
    <% end %>

    <%# ── Main content ── %>
    <main class="bg-gray-50 pt-4 lg:pt-8 lg:pb-8 flex-grow">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <%= yield %>
      </div>
    </main>

    <%# ── Footer (matches Paperbell) ── %>
    <footer class="bg-gray-200">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-3 text-center text-gray-500 text-sm">
        <a href="#" class="hover:text-gray-700 hover:underline">Support</a>
        <a href="#" class="ml-6 hover:text-gray-700 hover:underline">Terms and conditions</a>
        <a href="#" class="ml-6 hover:text-gray-700 hover:underline">Privacy policy</a>
        <span class="ml-6">
          <%= render "shared/feature_request_link",
                kind: "general",
                text: "Feature request",
                class: "hover:text-gray-700 hover:underline cursor-pointer focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-plum rounded" %>
        </span>
      </div>
    </footer>
  </div>
</body>
</html>
