<% content_for(:auth_max_width) { "sm:max-w-3xl" } %>
<% content_for(:auth_card_class) { "ts-auth-card-wide" } %>

<h2 class="ts-auth-title mb-6">Create your account</h2>

<%= form_with url: create_account_path, method: :post, class: "space-y-8", data: { turbo: false } do |f| %>
  <%# Read-only email %>
  <div>
    <label class="ts-label block mb-1">Email</label>
    <p class="ts-input w-full bg-surface-secondary text-text-muted cursor-not-allowed"><%= current_user.email %></p>
  </div>

  <%# Personal Information %>
  <fieldset>
    <legend class="ts-subsection-heading mb-4">Personal Information</legend>

    <div class="grid grid-cols-1 gap-4">
      <div>
        <%= f.label :first_name, "First Name", class: "ts-label block mb-1" %>
        <%= f.text_field :first_name,
          value: params[:first_name],
          required: true,
          maxlength: 50,
          autocomplete: "given-name",
          placeholder: "Lucy",
          class: "ts-input w-full" %>
      </div>

      <div>
        <%= f.label :last_name, "Last Name", class: "ts-label block mb-1" %>
        <%= f.text_field :last_name,
          value: params[:last_name],
          required: true,
          maxlength: 50,
          autocomplete: "family-name",
          placeholder: "Miller",
          class: "ts-input w-full" %>
      </div>

      <div>
        <%= f.label :credentials, "Credentials", class: "ts-label block mb-1" %>
        <%= f.text_field :credentials,
          value: params[:credentials],
          maxlength: 50,
          placeholder: "PhD, OTR/L",
          class: "ts-input w-full" %>
      </div>

      <div>
        <%= f.label :profession_id, "Profession", class: "ts-label block mb-1" %>
        <%= f.select :profession_id,
          options_from_collection_for_select(@professions, :id, :name, params[:profession_id]),
          { include_blank: "Select a profession" },
          { required: true, class: "ts-select w-full" } %>
        <p class="text-xs text-text-muted mt-1">Don't see your profession? Email support@therasaurus.org</p>
      </div>
    </div>
  </fieldset>

  <%# Primary Business Location %>
  <fieldset>
    <legend class="ts-subsection-heading mb-4">Primary Business Location</legend>

    <div class="grid grid-cols-1 gap-4">
      <div>
        <%= f.label :street_address, "Street Address", class: "ts-label block mb-1" %>
        <%= f.text_field :street_address,
          value: params[:street_address],
          required: true,
          maxlength: 120,
          autocomplete: "street-address",
          class: "ts-input w-full" %>
      </div>

      <div>
        <%= f.label :street_address2, "Suite / Unit / Floor", class: "ts-label block mb-1" %>
        <%= f.text_field :street_address2,
          value: params[:street_address2],
          maxlength: 120,
          autocomplete: "address-line2",
          class: "ts-input w-full" %>
      </div>

      <%= render "shared/zip_combobox",
            name_prefix: "location",
            index: 0,
            zip: params.dig(:location, :zip),
            city: params.dig(:location, :city),
            state: params.dig(:location, :state),
            latitude: params.dig(:location, :latitude),
            longitude: params.dig(:location, :longitude),
            city_match: params.dig(:location, :city_match_successful) == "1" %>

      <div>
        <%= f.label :country_id, "Country", class: "ts-label block mb-1" %>
        <%= f.select :country_id,
          options_from_collection_for_select(@countries, :id, :name, params[:country_id] || @countries.find_by(code: "US")&.id),
          { include_blank: "Select a country" },
          { required: true, class: "ts-select w-full" } %>
        <p class="text-xs text-text-muted mt-1">TheraSaurus currently supports US-based providers only.</p>
      </div>

      <div>
        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.check_box :show_street_address,
            { checked: params[:show_street_address] != "0" },
            "1", "0" %>
          <span class="ts-label">Show street address on my profile</span>
        </label>
      </div>
    </div>
  </fieldset>

  <div class="flex justify-end">
    <%= f.submit "Create Account", class: "ts-btn-primary px-8 py-2.5 text-base" %>
  </div>
<% end %>
