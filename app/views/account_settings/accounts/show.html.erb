<%= render layout: "account_settings/shared/layout" do %>
  <section class="ts-card">
    <%# ── Profile pic ── %>
    <div class="mb-6 pb-6 border-b border-gray-100" data-controller="profile-photo-upload">
      <span class="ts-label block mb-2">Profile pic</span>
      <div class="flex flex-col items-start gap-3">
        <div class="h-20 w-20 rounded-full bg-plum-bg flex items-center justify-center overflow-hidden flex-shrink-0">
          <img src="<%= therapist&.practice_image_url %>"
               alt="Profile photo"
               class="h-full w-full object-cover <%= 'hidden' unless therapist&.practice_image_url.present? %>"
               data-profile-photo-upload-target="image">
          <span class="text-lg font-semibold text-plum <%= 'hidden' if therapist&.practice_image_url.present? %>"
                data-profile-photo-upload-target="initials">
            <%= initials_for(therapist, current_user) %>
          </span>
        </div>
        <button type="button"
                class="inline-flex shrink-0 items-center gap-2 rounded-md border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-text-primary shadow-sm hover:bg-gray-50 cursor-pointer"
                data-action="profile-photo-upload#pick">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" /></svg>
          Change
        </button>
        <p class="text-xs hidden" data-profile-photo-upload-target="status" aria-live="polite"></p>
      </div>
      <input type="file"
             accept="image/jpeg,image/png"
             class="hidden"
             data-profile-photo-upload-target="input"
             data-action="change->profile-photo-upload#openCropper"
             aria-label="Upload profile photo">

      <%# ── Crop dialog ── %>
      <dialog data-profile-photo-upload-target="dialog"
              class="m-auto p-0 bg-transparent max-w-[600px] w-full max-h-dvh backdrop:bg-gray-950/80 backdrop:backdrop-blur-sm rounded-2xl">
        <div class="bg-white rounded-2xl shadow-lg flex flex-col max-h-dvh overflow-hidden">
          <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
            <div>
              <h3 class="text-lg font-heading font-semibold text-text-primary">Crop Image</h3>
              <p class="text-sm text-text-muted mt-0.5">Drag the containing box to ensure your final image is optimized.</p>
            </div>
            <button type="button"
                    data-action="profile-photo-upload#cancelCrop"
                    class="flex items-center justify-center w-9 h-9 rounded-full bg-gray-100 text-text-muted hover:bg-gray-200 cursor-pointer"
                    aria-label="Cancel cropping">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
          </div>

          <div class="p-4 min-h-0 flex-1 overflow-hidden">
            <img data-profile-photo-upload-target="cropImage"
                 alt="Image to crop"
                 class="block max-w-full max-h-[60vh]">
          </div>

          <div class="flex items-center justify-end gap-3 px-5 py-4 border-t border-gray-100">
            <button type="button"
                    data-action="profile-photo-upload#cancelCrop"
                    class="ts-btn-outline px-4 py-2">
              Cancel
            </button>
            <button type="button"
                    data-action="profile-photo-upload#confirmCrop"
                    class="ts-btn-primary px-4 py-2">
              Crop & Upload
            </button>
          </div>
        </div>
      </dialog>
    </div>

    <%# ── Account details form ── %>
    <%= form_with model: therapist, url: account_path, method: :patch,
          data: { controller: "form-guard" }, class: "space-y-5" do |f| %>
      <div>
        <%= f.label :first_name, class: "ts-label block mb-1.5" %>
        <%= f.text_field :first_name, class: "ts-input block w-full sm:w-1/2", autocomplete: "given-name" %>
      </div>

      <div>
        <%= f.label :last_name, class: "ts-label block mb-1.5" %>
        <%= f.text_field :last_name, class: "ts-input block w-full sm:w-1/2", autocomplete: "family-name" %>
      </div>

      <div>
        <%= f.label :profession_id, "Profession", class: "ts-label block mb-1.5" %>
        <%= f.collection_select :profession_id, Profession.order(:name), :id, :name,
              { prompt: "Select profession" }, class: "ts-select block w-full sm:w-1/2" %>
      </div>

      <div>
        <%= f.label :credentials, class: "ts-label block mb-1.5" %>
        <%= f.text_field :credentials, class: "ts-input block w-full sm:w-1/2",
              placeholder: "e.g. MSR, OTR/L", autocomplete: "off" %>
      </div>

      <div class="flex justify-end pt-5 border-t border-gray-100">
        <%= f.submit "Save", class: "ts-btn-primary px-6 py-2.5" %>
      </div>
    <% end %>
  </section>
<% end %>
