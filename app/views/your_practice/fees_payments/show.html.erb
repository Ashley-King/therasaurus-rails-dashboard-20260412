<%= render layout: "your_practice/shared/layout" do %>
  <%# ── Session fees card ── %>
  <section class="ts-card mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Session fees</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark hover:underline">Edit</a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <dl class="grid grid-cols-[260px_1fr] gap-y-2 text-sm">
        <dt class="text-text-muted">Assessment/evaluation fee</dt>
        <dd class="text-text-primary"><%= therapist&.evaluation_fee.present? ? number_to_currency(therapist.evaluation_fee) : "Not provided" %></dd>

        <dt class="text-text-muted">Individual therapy fee</dt>
        <dd class="text-text-primary"><%= therapist&.therapy_fee.present? ? number_to_currency(therapist.therapy_fee) : "Not provided" %></dd>

        <dt class="text-text-muted">Group therapy fee</dt>
        <dd class="text-text-primary"><%= therapist&.group_therapy_fee.present? ? number_to_currency(therapist.group_therapy_fee) : "Not provided" %></dd>

        <dt class="text-text-muted">Consultation fee</dt>
        <dd class="text-text-primary"><%= therapist&.consultation_fee.present? ? number_to_currency(therapist.consultation_fee) : "Not provided" %></dd>

        <dt class="text-text-muted">No-show/late cancellation fee</dt>
        <dd class="text-text-primary"><%= therapist&.late_cancellation_fee.present? ? number_to_currency(therapist.late_cancellation_fee) : "Not provided" %></dd>
      </dl>
    </div>
  </section>

  <%# ── Payment methods card ── %>
  <section class="ts-card mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Payment methods</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark hover:underline">Edit</a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% if therapist&.payment_methods&.any? %>
        <p class="text-sm text-text-primary"><%= therapist.payment_methods.order(:name).pluck(:name).join(", ") %></p>
      <% else %>
        <p class="text-sm text-text-muted">No payment methods added yet.</p>
      <% end %>
    </div>
  </section>

  <%# ── Insurance card ── %>
  <section class="ts-card mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Insurance</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark hover:underline">Edit</a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% if therapist&.insurance_companies&.any? %>
        <p class="text-sm text-text-primary"><%= therapist.insurance_companies.order(:name).pluck(:name).join(", ") %></p>
      <% else %>
        <p class="text-sm text-text-muted">No insurance companies added yet.</p>
      <% end %>
    </div>
  </section>

  <%# ── Fee notes card ── %>
  <section class="ts-card mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Notes about your fees</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark hover:underline"><%= therapist&.fee_notes.present? ? "Edit" : "Add" %></a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% if therapist&.fee_notes.present? %>
        <p class="text-sm text-text-primary whitespace-pre-line"><%= therapist.fee_notes %></p>
      <% else %>
        <p class="text-sm text-text-muted">Add notes about your fees.</p>
      <% end %>
    </div>
  </section>

  <%# ── Cancellation policy card ── %>
  <section class="ts-card">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Cancellation policy</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark hover:underline">Add</a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <p class="text-sm text-text-muted">Add your cancellation policy.</p>
    </div>
  </section>
<% end %>
