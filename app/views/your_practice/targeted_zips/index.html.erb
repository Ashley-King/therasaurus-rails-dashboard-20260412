<% at_cap = @targeted_zips.size >= TherapistTargetedZip::MAX_PER_THERAPIST %>

<%= render layout: "your_practice/shared/layout" do %>
  <section class="ts-card mb-6">
    <h2 class="text-lg font-heading font-semibold text-text-primary mb-1">Targeted ZIPs</h2>
    <p class="text-sm text-text-muted mb-4">
      Add up to <%= TherapistTargetedZip::MAX_PER_THERAPIST %> ZIP codes where you'd like to appear in search results, even if you don't have a physical office there.
    </p>

    <%# Count indicator %>
    <p class="text-sm text-text-muted mb-4">
      <span class="font-semibold text-text-primary"><%= @targeted_zips.size %></span> of <%= TherapistTargetedZip::MAX_PER_THERAPIST %> saved
    </p>

    <%# Chip list %>
    <% if @targeted_zips.any? %>
      <ul class="flex flex-wrap gap-2 mb-6" aria-label="Your targeted ZIPs">
        <% @targeted_zips.each do |tz| %>
          <li class="inline-flex items-center gap-2 rounded-full border border-border-default bg-surface-secondary pl-3 pr-1 py-1">
            <span class="text-sm text-text-primary">
              <span class="font-medium"><%= tz.zip %></span> — <%= tz.city %>, <%= tz.state %>
            </span>
            <%= form_with url: targeted_zip_path(tz), method: :delete,
                  data: { turbo_confirm: "Remove targeted ZIP #{tz.zip} — #{tz.city}, #{tz.state}?" },
                  class: "inline-flex" do %>
              <button type="submit"
                      aria-label="Remove targeted ZIP <%= tz.zip %>"
                      class="inline-flex items-center justify-center h-6 w-6 rounded-full text-text-muted hover:text-text-primary hover:bg-gray-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-plum focus:ring-offset-1">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </button>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-text-muted mb-6">No targeted ZIPs added yet.</p>
    <% end %>

    <%# Add form %>
    <div class="pt-5 border-t border-gray-100">
      <h3 class="text-base font-semibold text-text-primary mb-1">Add a targeted ZIP</h3>
      <% if at_cap %>
        <p class="text-sm text-text-muted">You've reached the <%= TherapistTargetedZip::MAX_PER_THERAPIST %>-ZIP limit. Remove one above to add another.</p>
      <% else %>
        <%= form_with model: @targeted_zip, url: targeted_zips_path, method: :post,
              data: { controller: "form-guard", turbo: false }, class: "space-y-6 mt-4" do %>

          <% if @targeted_zip.errors.any? %>
            <div class="rounded-lg bg-red-50 border border-red-200 p-3">
              <p class="text-sm text-red-700"><%= @targeted_zip.errors.full_messages.to_sentence %></p>
            </div>
          <% end %>

          <%= render "shared/zip_combobox",
                name_prefix: "targeted_zip",
                index: 2,
                zip: @targeted_zip.zip,
                city: @targeted_zip.city,
                state: @targeted_zip.state,
                latitude: @targeted_zip.latitude,
                longitude: @targeted_zip.longitude,
                city_match: @targeted_zip.city_match_successful %>

          <div class="flex justify-end">
            <%= submit_tag "Add targeted ZIP", class: "ts-btn-primary px-6 py-2.5 cursor-pointer" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
