<% content_for :page_header do %>
  <h1 class="font-heading text-3xl md:text-4xl font-bold text-text-primary">Services & Specialties</h1>
<% end %>

<%= render layout: "your_practice/shared/layout" do %>
  <%# ── Services card ── %>
  <section class="ts-card mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Services</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark"><%= therapist&.services&.any? ? "Edit" : "Add" %></a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% if therapist&.services&.any? %>
        <p class="text-sm text-text-primary"><%= therapist.services.order(:name).pluck(:name).join(", ") %></p>
      <% else %>
        <p class="text-sm text-text-muted">Add your services.</p>
      <% end %>
    </div>
  </section>

  <%# ── Focus specialties card ── %>
  <% focus_specialties = therapist&.practice_specialties&.where(is_focus: true)&.includes(:specialty) || [] %>
  <% other_specialties = therapist&.practice_specialties&.where(is_focus: false)&.includes(:specialty) || [] %>

  <section class="ts-card mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Focus specialties</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark"><%= focus_specialties.any? ? "Edit" : "Add" %></a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% if focus_specialties.any? %>
        <p class="text-sm text-text-primary"><%= focus_specialties.map { |ps| ps.specialty.name }.sort.join(", ") %></p>
      <% else %>
        <p class="text-sm text-text-muted">Add up to 5 focus specialties.</p>
      <% end %>
      <p class="text-xs text-text-muted mt-2">Up to 5 focus specialties. These are highlighted on your profile.</p>
    </div>
  </section>

  <%# ── Other areas of expertise card ── %>
  <section class="ts-card">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Other areas of expertise</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark"><%= other_specialties.any? ? "Edit" : "Add" %></a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% if other_specialties.any? %>
        <p class="text-sm text-text-primary"><%= other_specialties.map { |ps| ps.specialty.name }.sort.join(", ") %></p>
      <% else %>
        <p class="text-sm text-text-muted">Add your other areas of expertise.</p>
      <% end %>
    </div>
  </section>
<% end %>
