<% content_for :page_header do %>
  <h1 class="font-heading text-3xl md:text-4xl font-bold text-text-primary">Locations</h1>
<% end %>

<%= render layout: "your_practice/shared/layout" do %>
  <%# ── Practice locations card ── %>
  <section class="ts-card mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Practice locations</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark">Edit</a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% if @locations&.any? %>
        <dl class="grid grid-cols-[200px_1fr] gap-y-2 text-sm">
          <% @locations.each do |location| %>
            <dt class="text-text-muted"><%= location.location_type&.titleize %> location</dt>
            <dd class="text-text-primary">
              <p><%= location.street_address %></p>
              <% if location.street_address2.present? %>
                <p><%= location.street_address2 %></p>
              <% end %>
              <p><%= location.city %>, <%= location.state %> <%= location.zip %></p>
            </dd>

            <dt class="text-text-muted">Show street address on profile</dt>
            <dd class="text-text-primary"><%= location.show_street_address? ? "Yes" : "No" %></dd>
          <% end %>
        </dl>
      <% else %>
        <p class="text-sm text-text-muted">No locations added yet.</p>
      <% end %>
    </div>
  </section>

  <%# ── Targeted zip codes card ── %>
  <section class="ts-card">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Targeted zip codes</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark">Edit</a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <p class="text-sm text-text-muted">No additional targeted zip codes added yet.</p>
      <p class="text-xs text-text-muted mt-2">You can add up to 5 targeted zip codes to help clients find you.</p>
    </div>
  </section>
<% end %>
