<% content_for :page_header do %>
  <h1 class="font-heading text-3xl md:text-4xl font-bold text-text-primary">Introduction</h1>
<% end %>

<%= render layout: "your_practice/shared/layout" do %>
  <section class="ts-card">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Introduce your practice</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark"><%= therapist&.practice_description.present? ? "Edit" : "Add" %></a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% if therapist&.practice_description.present? %>
        <p class="text-sm text-text-primary whitespace-pre-line"><%= therapist.practice_description %></p>
      <% else %>
        <p class="text-sm text-text-muted">Add an introduction to your practice.</p>
      <% end %>
    </div>
  </section>
<% end %>
