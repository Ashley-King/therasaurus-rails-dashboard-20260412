<%= render layout: "your_practice/shared/layout" do %>
  <section class="ts-card"
           data-controller="services-picker"
           data-services-picker-max-value="<%= @max_services %>">
    <div class="mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary mb-1">Services</h2>
      <p class="text-sm text-text-primary">Pick every service you offer, up to <%= @max_services %>. Filter by category or search to narrow the list.</p>
    </div>

    <%= form_with model: therapist, url: services_path, method: :patch,
          data: { controller: "form-guard" }, class: "space-y-6" do |f| %>

      <%# ── Selected chips ── %>
      <div class="mb-5 border border-border-default rounded-lg p-4">
        <div class="flex items-baseline justify-between mb-2">
          <h3 class="text-sm font-semibold text-text-primary">
            Selected (<span data-services-picker-target="selectedCount">0</span>/<%= @max_services %>)
          </h3>
        </div>
        <div data-services-picker-target="selectedChips" class="flex flex-wrap items-start content-start gap-2 h-48 overflow-y-auto pr-1"></div>
      </div>

      <%# ── Search ── %>
      <div class="mb-4">
        <label for="services_search" class="sr-only">Search services</label>
        <div class="relative">
          <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-text-muted">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.3-4.3m0 0A7 7 0 1 0 6.8 6.8a7 7 0 0 0 9.9 9.9Z"/>
            </svg>
          </span>
          <input type="search"
                 id="services_search"
                 data-services-picker-target="search"
                 data-action="input->services-picker#onSearch"
                 placeholder="Search services…"
                 autocomplete="off"
                 class="ts-input block w-full pl-9">
        </div>
      </div>

      <%# ── Category filters ── %>
      <div class="mb-4">
        <h3 class="text-sm font-semibold text-text-primary mb-2">Filter by category</h3>

        <label for="service_category_select" class="sr-only">Filter by category</label>
        <select id="service_category_select"
                data-services-picker-target="categorySelect"
                data-action="change->services-picker#selectCategory"
                class="ts-select block w-full sm:w-1/2 cursor-pointer">
          <option value="">All categories</option>
          <% @service_categories.each do |id, name| %>
            <option value="<%= id %>"><%= name %></option>
          <% end %>
        </select>

        <div class="mt-2 flex items-center gap-4">
          <button type="button"
                  data-action="click->services-picker#clearFilters"
                  class="text-xs font-semibold text-teal hover:text-teal-dark hover:underline cursor-pointer focus:outline-none focus:ring-2 focus:ring-plum focus:ring-offset-1 rounded">
            Clear filters
          </button>
          <%= render "shared/feature_request_link",
                kind: "service",
                class: "text-xs font-semibold text-teal hover:text-teal-dark hover:underline cursor-pointer focus:outline-none focus:ring-2 focus:ring-plum focus:ring-offset-1 rounded" %>
        </div>
      </div>

      <%# ── Service list ── %>
      <div class="border-t border-gray-100 pt-4">
        <p class="text-xs text-text-primary mb-3">
          Showing <span data-services-picker-target="visibleCount"><%= @services.size %></span> of <%= @services.size %> services
        </p>

        <%# Hidden field so unchecking every service still submits an empty array %>
        <input type="hidden" name="therapist[service_ids][]" value="">

        <ul class="divide-y divide-gray-100 max-h-[480px] overflow-y-auto">
          <% @services.each do |service| %>
            <li data-services-picker-target="service"
                data-service-id="<%= service[:id] %>"
                data-service-name="<%= service[:name] %>"
                data-category-ids="<%= service[:category_ids].join(" ") %>">
              <label class="flex items-start gap-2.5 py-2.5 px-1 text-base text-text-primary cursor-pointer hover:bg-gray-50">
                <input type="checkbox"
                       name="therapist[service_ids][]"
                       value="<%= service[:id] %>"
                       <%= "checked" if @selected_service_ids.include?(service[:id].to_s) %>
                       data-action="change->services-picker#onServiceChange"
                       class="mt-1 h-4 w-4 shrink-0 rounded border-border-input accent-plum focus:ring-2 focus:ring-plum focus:ring-offset-1 cursor-pointer">
                <span><%= service[:name] %></span>
              </label>
            </li>
          <% end %>
        </ul>

        <p data-services-picker-target="empty" hidden class="text-sm text-text-primary text-center py-6">
          No services match your search or filters.
        </p>
      </div>

      <div class="flex justify-end pt-5 border-t border-gray-100">
        <%= f.submit "Save", class: "ts-btn-primary px-6 py-2.5 cursor-pointer" %>
      </div>
    <% end %>
  </section>
<% end %>
