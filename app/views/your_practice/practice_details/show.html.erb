<% content_for :page_header do %>
  <h1 class="font-heading text-3xl md:text-4xl font-bold text-text-primary">Practice Details</h1>
<% end %>

<%= render layout: "your_practice/shared/layout" do %>
  <%# ── Practice information card ── %>
  <section class="ts-card mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Practice information</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark">Edit</a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% if therapist.present? %>
        <dl class="grid grid-cols-[200px_1fr] gap-y-2 text-sm">
          <dt class="text-text-muted">Practice name</dt>
          <dd class="text-text-primary"><%= therapist.practice_name.presence || "No practice name added" %></dd>

          <dt class="text-text-muted">Use practice name instead of real name</dt>
          <dd class="text-text-primary"><%= therapist.use_practice_name? ? "Yes" : "No" %></dd>

          <dt class="text-text-muted">Website</dt>
          <dd class="text-text-primary"><%= therapist.practice_website_url.presence || "Not provided" %></dd>

          <dt class="text-text-muted">Phone number</dt>
          <dd class="text-text-primary"><%= therapist.phone_number.presence || "Not provided" %></dd>

          <dt class="text-text-muted">Phone extension</dt>
          <dd class="text-text-primary"><%= therapist.phone_ext.presence || "Not provided" %></dd>

          <dt class="text-text-muted">Show phone number on profile</dt>
          <dd class="text-text-primary"><%= therapist.show_phone_number? ? "Yes" : "No" %></dd>
        </dl>
      <% else %>
        <p class="text-sm text-text-muted">No practice information added yet.</p>
      <% end %>
    </div>
  </section>

  <%# ── Accessibility card ── %>
  <section class="ts-card mb-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Accessibility</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark">Edit</a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% if therapist&.accessibility_options&.any? %>
        <p class="text-sm text-text-primary"><%= therapist.accessibility_options.order(:name).pluck(:name).join(", ") %></p>
      <% else %>
        <p class="text-sm text-text-muted">No accessibility features added yet.</p>
      <% end %>
    </div>
  </section>

  <%# ── Social media card ── %>
  <section class="ts-card">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Social media</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark">Edit</a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% social = therapist&.social_media || {} %>
      <dl class="grid grid-cols-[200px_1fr] gap-y-2 text-sm">
        <% %w[facebook instagram linkedin pinterest substack threads tiktok youtube x].each do |platform| %>
          <dt class="text-text-muted"><%= platform.capitalize %></dt>
          <dd class="text-text-primary"><%= social[platform].presence || "Not provided" %></dd>
        <% end %>
      </dl>
    </div>
  </section>
<% end %>
