<%
  copy = feature_request_copy(kind)
  fr ||= FeatureRequest.new(kind: kind, body: nil)
%>
<div class="space-y-4">
  <div class="relative">
    <button type="button"
            aria-label="Close"
            class="absolute top-0 right-0 text-text-muted hover:text-text-primary cursor-pointer rounded focus:outline-none focus:ring-2 focus:ring-offset-1 focus:ring-plum"
            data-action="click->feature-request#close">
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M6 18L18 6"/>
      </svg>
    </button>
    <div class="mx-auto max-w-[300px] text-center">
      <h2 class="text-xl font-heading font-semibold text-text-primary"><%= copy[:title] %></h2>
      <% if copy[:lead].present? %>
        <p class="mt-1 text-sm text-text-primary"><%= copy[:lead] %></p>
      <% end %>
    </div>
  </div>

  <%= form_with model: fr, url: feature_requests_path, html: { class: "space-y-4 text-left" } do |f| %>
    <%= hidden_field_tag :frame_id, frame_id %>
    <%= f.hidden_field :kind, value: kind %>
    <%= f.hidden_field :page_url, value: page_url %>

    <% if fr.errors.any? %>
      <div role="alert" class="rounded-md bg-red-50 border border-red-200 px-3 py-2 text-sm text-red-800">
        <%= fr.errors.full_messages.first %>
      </div>
    <% end %>

    <div>
      <%= f.label :body, copy[:label], class: "ts-label block mb-1" %>
      <% if copy[:label_help].present? %>
        <p class="text-xs text-text-muted mb-2"><%= copy[:label_help] %></p>
      <% end %>
      <%= f.text_area :body,
            rows: 5,
            class: "ts-input block w-full",
            placeholder: copy[:placeholder],
            required: true,
            maxlength: 2000,
            autofocus: true %>
    </div>

    <div class="flex flex-col-reverse sm:flex-row sm:justify-end gap-2 pt-2">
      <button type="button" class="ts-btn-outline cursor-pointer" data-action="click->feature-request#close">Cancel</button>
      <%= f.submit "Send request", class: "ts-btn-primary cursor-pointer" %>
    </div>
  <% end %>
</div>
