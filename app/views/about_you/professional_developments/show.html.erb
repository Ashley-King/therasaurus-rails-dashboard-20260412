<%= render layout: "about_you/shared/layout" do %>
  <div class="ts-card">
    <%= form_with url: professional_development_path, method: :patch,
          data: { controller: "form-guard" }, class: "space-y-8" do %>

      <section data-controller="training-slots">
        <h2 class="text-lg font-heading font-semibold text-text-primary mb-1">Additional training</h2>
        <p class="text-sm text-text-muted mb-4">Talk about any additional training or advanced certifications you may have. Add up to three.</p>

        <div class="space-y-4">
          <% 3.times do |idx| %>
            <% row = @training_rows[idx] || {} %>
            <% is_hidden = idx > 0 && row[:description].blank? %>

            <div data-training-slots-target="slot"
                 class="rounded-lg border border-gray-200 p-4"
                 <%= "hidden" if is_hidden %>>
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-sm font-semibold text-text-primary">Certification or training</h3>
                <% if idx > 0 %>
                  <button type="button"
                          data-action="click->training-slots#remove"
                          class="text-sm text-text-muted hover:text-text-primary hover:underline cursor-pointer focus:outline-none focus:ring-2 focus:ring-plum focus:ring-offset-1 rounded">
                    Remove
                  </button>
                <% end %>
              </div>

              <div class="mb-4">
                <label for="training_<%= idx %>_year" class="ts-label block mb-1.5">Year <span class="font-normal text-text-muted">(optional)</span></label>
                <input type="text"
                       id="training_<%= idx %>_year"
                       name="training[<%= idx %>][year]"
                       value="<%= row[:year] %>"
                       inputmode="numeric"
                       pattern="\d{4}"
                       maxlength="4"
                       autocomplete="off"
                       placeholder="2012"
                       data-controller="digits-only"
                       data-action="input->digits-only#filter"
                       class="ts-input block w-full sm:w-32">
              </div>

              <div data-controller="char-counter">
                <label for="training_<%= idx %>_description" class="ts-label block mb-1.5">Description <span class="font-normal text-text-muted">(up to 300 characters)</span></label>
                <textarea id="training_<%= idx %>_description"
                          name="training[<%= idx %>][description]"
                          rows="2"
                          maxlength="<%= TherapistContinuingEducation::DESCRIPTION_MAX_LENGTH %>"
                          autocomplete="off"
                          placeholder="C/NDT (Neuro-developmental Treatment) Certification"
                          data-char-counter-target="field"
                          data-action="input->char-counter#update"
                          class="ts-input block w-full"><%= row[:description] %></textarea>
                <p class="mt-1 text-xs text-text-muted text-right" data-char-counter-target="output" aria-live="polite"></p>
              </div>
            </div>
          <% end %>

          <%
            show_add = (1..2).any? { |i| (@training_rows[i] || {})[:description].blank? }
          %>
          <button type="button"
                  data-training-slots-target="addButton"
                  data-action="click->training-slots#add"
                  <%= "hidden" unless show_add %>
                  class="group inline-flex items-center gap-1.5 text-sm font-medium text-teal hover:text-teal-dark cursor-pointer focus:outline-none focus:ring-2 focus:ring-teal focus:ring-offset-1 rounded px-1 py-1">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
            <span class="group-hover:underline">Add another certification or training</span>
          </button>
        </div>
      </section>

      <div class="flex justify-end pt-5 border-t border-gray-100">
        <%= submit_tag "Save", class: "ts-btn-primary px-6 py-2.5 cursor-pointer" %>
      </div>
    <% end %>
  </div>
<% end %>
