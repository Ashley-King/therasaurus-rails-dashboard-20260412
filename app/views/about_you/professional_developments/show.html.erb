<% content_for :page_header do %>
  <h1 class="font-heading text-3xl md:text-4xl font-bold text-text-primary">Professional Development</h1>
<% end %>

<%= render layout: "about_you/shared/layout" do %>
  <section class="ts-card">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Additional training</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark">Edit</a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% if therapist&.therapist_continuing_education&.any? %>
        <% therapist.therapist_continuing_education.each do |ce| %>
          <div class="mb-3 last:mb-0">
            <p class="text-sm text-text-primary"><%= ce.description %></p>
          </div>
        <% end %>
      <% else %>
        <p class="text-sm text-text-muted">No training added yet.</p>
      <% end %>
    </div>
  </section>
<% end %>
