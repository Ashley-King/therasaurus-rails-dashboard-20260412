<% content_for :page_header do %>
  <h1 class="font-heading text-3xl md:text-4xl font-bold text-text-primary">Primary Credential</h1>
<% end %>

<%= render layout: "about_you/shared/layout" do %>
  <section class="ts-card">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-heading font-semibold text-text-primary">Your credential</h2>
      <a href="#" class="text-sm font-semibold text-teal hover:text-teal-dark">Edit</a>
    </div>
    <div class="border border-gray-200 rounded-lg p-5">
      <% if therapist&.user_credentials&.any? %>
        <% credential = therapist.user_credentials.first %>
        <dl class="grid grid-cols-[160px_1fr] gap-y-2 text-sm">
          <dt class="text-text-muted">Type</dt>
          <dd class="text-text-primary"><%= credential.credential_type %></dd>

          <dt class="text-text-muted">Status</dt>
          <dd>
            <span class="<%= credential.credential_status == 'VERIFIED' ? 'ts-badge-active' : 'ts-badge-attention' %>">
              <%= credential.credential_status.titleize %>
            </span>
          </dd>
        </dl>
      <% else %>
        <p class="text-sm text-text-muted">No credential added yet.</p>
      <% end %>
    </div>
  </section>
<% end %>
