<% content_for :page_header do %>
  <h1 class="font-heading text-3xl md:text-4xl font-bold text-text-primary">Update Email</h1>
<% end %>

<%= render layout: "about_you/shared/layout" do %>
  <section class="ts-card">
    <h2 class="text-lg font-heading font-semibold text-text-primary mb-4">Email address</h2>
    <div class="border border-gray-200 rounded-lg p-5">
      <p class="text-sm text-text-primary"><%= current_user.email %></p>
      <p class="mt-2 text-xs text-text-muted">Email changes are handled through Supabase Auth. Contact support if you need to update your email.</p>
    </div>
  </section>
<% end %>
