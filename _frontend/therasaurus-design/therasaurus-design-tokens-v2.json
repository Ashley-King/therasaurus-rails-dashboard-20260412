{
  "meta": {
    "source": "therasaurus.org",
    "version": "2.0",
    "revised": "2026-04-07",
    "framework": "Tailwind CSS v4 (with custom CSS properties)",
    "notes": "Revised design system. Adopts Paperbell's structural rigor (clear gray hierarchy, consistent button tiers, clean naming) while preserving Therasaurus branding (plum/teal palette, Poppins/Roboto type pairing, therapy-specific components)."
  },
  "typography": {
    "families": {
      "primary": "Roboto, ui-sans-serif, system-ui, sans-serif",
      "heading": "Poppins, ui-sans-serif, system-ui, sans-serif"
    },
    "sizes": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "24px",
      "3xl": "30px",
      "hero": "48px"
    },
    "weights": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeights": {
      "tight": "1.2",
      "snug": "20px",
      "normal": "24px",
      "relaxed": "1.625",
      "heading": "32px"
    }
  },
  "colors": {
    "text": {
      "primary": { "hex": "#0A0A0A", "rgb": "rgb(10, 10, 10)", "usage": "Page headings (H1)" },
      "secondary": { "hex": "#414141", "rgb": "rgb(65, 65, 65)", "usage": "Labels, bold body text, nav links" },
      "body": { "hex": "#4B5563", "rgb": "rgb(75, 86, 99)", "usage": "Default body text, descriptions" },
      "muted": { "hex": "#737373", "rgb": "rgb(115, 115, 115)", "usage": "Helper text, captions, timestamps" },
      "placeholder": { "hex": "#A3A3A3", "rgb": "rgb(163, 163, 163)", "usage": "Input placeholders, disabled nav" },
      "disabled": { "hex": "#D4D4D4", "rgb": "rgb(212, 212, 212)", "usage": "Disabled elements" },
      "inverse": { "hex": "#FFFFFF", "rgb": "rgb(255, 255, 255)", "usage": "Text on dark/plum backgrounds" }
    },
    "brand": {
      "plum": { "hex": "#795B83", "rgb": "rgb(121, 91, 131)", "usage": "Primary brand. Section headings (H2), active sidebar, primary buttons" },
      "plumDark": { "hex": "#5C3F66", "rgb": "rgb(92, 63, 102)", "usage": "Hover state for plum buttons, footer background" },
      "plumBg": { "hex": "#F3F1F6", "rgb": "rgb(243, 241, 246)", "usage": "Plum-tinted section backgrounds, active sidebar bg" },
      "teal": { "hex": "#2FA0A0", "rgb": "rgb(47, 160, 160)", "usage": "Secondary brand. Category labels, links, subheadings" },
      "tealDark": { "hex": "#1E7A7A", "rgb": "rgb(30, 122, 122)", "usage": "Hover state for teal elements" },
      "tealBg": { "hex": "#E8F6F6", "rgb": "rgb(232, 246, 246)", "usage": "Info banners, teal-tinted backgrounds" }
    },
    "background": {
      "primary": { "hex": "#FFFFFF", "rgb": "rgb(255, 255, 255)", "usage": "Cards, inputs, dropdowns" },
      "secondary": { "hex": "#FAFAFA", "rgb": "rgb(250, 250, 250)", "usage": "Page background, sidebar" },
      "tertiary": { "hex": "#F3F1F6", "rgb": "rgb(243, 241, 246)", "usage": "Branded section backgrounds" },
      "dark": { "hex": "#795B83", "rgb": "rgb(121, 91, 131)", "usage": "Primary plum button, hero overlay" },
      "darkest": { "hex": "#5C3F66", "rgb": "rgb(92, 63, 102)", "usage": "Footer, darkest plum variant" },
      "warning": { "hex": "#FEF3C7", "rgb": "rgb(254, 243, 199)", "usage": "Warning banner background" },
      "info": { "hex": "#E8F6F6", "rgb": "rgb(232, 246, 246)", "usage": "Info banner background" }
    },
    "border": {
      "default": { "hex": "#E5E5E5", "rgb": "rgb(229, 229, 229)", "usage": "Standard borders, dividers" },
      "input": { "hex": "#D4D4D4", "rgb": "rgb(212, 212, 212)", "usage": "Form input borders" },
      "plum": { "hex": "#795B83", "rgb": "rgb(121, 91, 131)", "usage": "Plum button borders, focused inputs" },
      "warning": { "hex": "#FDE68A", "rgb": "rgb(253, 230, 138)", "usage": "Warning banner border" }
    },
    "status": {
      "active": { "hex": "#059669", "rgb": "rgb(5, 150, 105)", "usage": "Active/success badge text" },
      "activeBg": { "hex": "#D1FAE5", "rgb": "rgb(209, 250, 229)", "usage": "Active/success badge background" },
      "attention": { "hex": "#E40014", "rgb": "rgb(228, 0, 20)", "usage": "Error states, required markers, attention badges" },
      "attentionBg": { "hex": "#FEE2E2", "rgb": "rgb(254, 226, 226)", "usage": "Error/attention badge background" }
    },
    "chart": {
      "1": { "hex": "#795B83", "usage": "Plum (primary brand)" },
      "2": { "hex": "#2FA0A0", "usage": "Teal (secondary brand)" },
      "3": { "hex": "#104E64", "usage": "Dark teal" },
      "4": { "hex": "#F05100", "usage": "Orange" },
      "5": { "hex": "#FCBB00", "usage": "Gold" }
    }
  },
  "spacing": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px"
  },
  "borderRadius": {
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "12px",
    "2xl": "16px",
    "full": "9999px"
  },
  "shadows": {
    "xs": "rgba(16, 24, 40, 0.05) 0px 1px 2px 0px",
    "sm": "rgba(0, 0, 0, 0.1) 0px 1px 3px 0px, rgba(0, 0, 0, 0.1) 0px 1px 2px -1px",
    "md": "rgba(0, 0, 0, 0.1) 0px 4px 6px -1px, rgba(0, 0, 0, 0.1) 0px 2px 4px -2px",
    "lg": "rgba(0, 0, 0, 0.1) 0px 10px 15px -3px, rgba(0, 0, 0, 0.1) 0px 4px 6px -4px",
    "dropdown": "rgba(48, 49, 61, 0.08) 0px 16px 32px 0px, rgba(48, 49, 61, 0.12) 6px 0px 24px -6px, rgba(48, 49, 61, 0.06) 0px 0px 0px 1px"
  },
  "pages": {
    "home": "/",
    "childTherapyTypes": "/child-therapy-types",
    "therapyDetail": "/child-therapy-types/:type",
    "contact": "/contact",
    "signIn": "/signin",
    "parentResources": "/parent-resources/state-early-intervention-programs",
    "privacyPolicy": "/policies/privacy",
    "termsOfUse": "/policies/terms-of-use",
    "accessibility": "/policies/accessibility"
  }
}
